---
layout: null
---
[
  {% assign all_items = site.posts | concat: site.articles %}
  {% for item in all_items %}
  {
    "title": {{ item.title | jsonify }},
    "url": {{ item.url | relative_url | jsonify }},
    "date": {{ item.date | date: "%B %d, %Y" | jsonify }},
    "iso": {{ item.date | date: "%Y-%m-%d" | jsonify }},
    "categories": {{ item.categories | jsonify }},
    "excerpt": {{ item.excerpt | strip_html | normalize_whitespace | truncate: 200 | jsonify }},
    "publisher": {{ item.publisher | default: "StoxFeed" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
