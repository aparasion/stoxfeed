---
layout: null
---
{
  "posts": [
    {% for item in site.posts %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "date": {{ item.date | date: "%B %d, %Y" | jsonify }},
      "iso": {{ item.date | date: "%Y-%m-%d" | jsonify }},
      "categories": {{ item.categories | jsonify }},
      "excerpt": {{ item.excerpt | strip_html | normalize_whitespace | truncate: 200 | jsonify }},
      "publisher": {{ item.publisher | default: "StoxFeed" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "articles": [
    {% for item in site.articles %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "date": {{ item.date | date: "%B %d, %Y" | jsonify }},
      "subtitle": {{ item.subtitle | default: "" | jsonify }},
      "issue_line": {{ item.issue_line | default: "" | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "signals": [
    {% for sig in site.data.signals %}
    {
      "id": {{ sig.id | jsonify }},
      "title": {{ sig.title | jsonify }},
      "category": {{ sig.category | jsonify }},
      "status": {{ sig.current_status | jsonify }},
      "description": {{ sig.description | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
